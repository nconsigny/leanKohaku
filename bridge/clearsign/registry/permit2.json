{
  "$schema": "../specs/erc7730-v1.schema.json",
  "context": {
    "$id": "Permit2",
    "contract": {
      "deployments": [
        { "chainId": 1,        "address": "0x000000000022D473030F116dDEE9F6B43aC78BA3" },
        { "chainId": 11155111, "address": "0x000000000022D473030F116dDEE9F6B43aC78BA3" }
      ],
      "abi": [
        { "type": "function", "name": "approve", "inputs": [
          { "name": "token",    "type": "address" },
          { "name": "spender",  "type": "address" },
          { "name": "amount",   "type": "uint160" },
          { "name": "expiration","type": "uint48" }
        ] }
      ]
    }
  },
  "metadata": {
    "owner": "Uniswap Labs",
    "contractName": "Permit2",
    "info": { "url": "https://docs.uniswap.org/contracts/permit2/overview" }
  },
  "display": {
    "formats": {
      "approve(address token,address spender,uint160 amount,uint48 expiration)": {
        "intent": "Approve Permit2 allowance",
        "fields": [
          { "path": "token",      "label": "Token",      "format": "addressName" },
          { "path": "spender",    "label": "Spender",    "format": "addressName" },
          { "path": "amount",     "label": "Amount",     "format": "tokenAmount", "params": { "tokenPath": "token" } },
          { "path": "expiration", "label": "Expires at", "format": "date", "params": { "encoding": "timestamp" } }
        ]
      }
    }
  }
}
